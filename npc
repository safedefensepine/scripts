-- Dialogue (fire once only)
-- ──────────────────────────────────────────────

local function FireDialogue(npcName, dialogueType)
    if not StillValid() then return end
    if not npcName or npcName == "" then
        Library:Notify({ Title = "Error", Description = "No NPC selected.", Time = 3 })
        return
    end
    local fired = false
    pcall(function()
        if ReplicatedStorage.assets.npc_cache[npcName] then
            Event:FireServer(ReplicatedStorage.assets.npc_cache[npcName], dialogueType)
            fired = true
        end
    end)
    if not fired then
        pcall(function()
            if Workspace.Npcs[npcName] then
                Event:FireServer(Workspace.Npcs[npcName], dialogueType)
                fired = true
            end
        end)
    end
    if not fired then
        -- Last resort: search via FindQuestNPCInWorld
        local result = FindQuestNPCInWorld(npcName)
        if result then
            Event:FireServer(result.model, dialogueType)
            fired = true
        end
    end
    if not fired then
        Library:Notify({ Title = "Error", Description = "'" .. npcName .. "' not found.", Time = 3 })
        return
    end
    Library:Notify({ Title = "Dialogue", Description = npcName, Time = 2 })
end

