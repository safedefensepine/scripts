local function FindClosestPvPBoard()
    local map = Workspace:FindFirstChild("Map")
    if not map then return nil end
    local missionBoards = map:FindFirstChild("Mission Boards")
    if not missionBoards then return nil end
    local pvpFolder = missionBoards:FindFirstChild("PvP")
    if not pvpFolder then return nil end

    local char   = LocalPlayer.Character
    local root   = char and char:FindFirstChild("HumanoidRootPart")
    local bestModel, bestPart, bestDist = nil, nil, math.huge

    for _, board in ipairs(pvpFolder:GetChildren()) do
        local part = nil
        if board:IsA("BasePart") then
            part = board
        elseif board:IsA("Model") then
            part = board.PrimaryPart
                or board:FindFirstChildOfClass("BasePart")
                or board:FindFirstChildWhichIsA("BasePart", true)
        end
        if part then
            if root then
                local dist = (root.Position - part.Position).Magnitude
                if dist < bestDist then
                    bestDist  = dist
                    bestModel = board
                    bestPart  = part
                end
            else
                return { model = board, part = part }
            end
        end
    end
    if bestPart then
        return { model = bestModel, part = bestPart }
    end
    return nil
end

local function FireBoardPrompt(boardModel)
    local prompt = boardModel:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        pcall(function() fireproximityprompt(prompt) end)
        return true
    end
    if boardModel.Parent then
        prompt = boardModel.Parent:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            pcall(function() fireproximityprompt(prompt) end)
            return true
        end
    end
    return false
end

local function IsInPvPQueue()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return false end
    local notifs = gui:FindFirstChild("Notifications")
    if not notifs then return false end
    local holder = notifs:FindFirstChild("holder")
    if not holder then return false end

    if holder:FindFirstChild("Joined PvP Mission Queue.") then
        return true
    end
    for _, child in ipairs(holder:GetChildren()) do
        if child:IsA("TextLabel") then
            if child.Text:lower():find("joined pvp mission queue") then return true end
        end
        for _, desc in ipairs(child:GetDescendants()) do
            if desc:IsA("TextLabel") then
                if desc.Text:lower():find("joined pvp mission queue") then return true end
            end
        end
    end
    return false
end

local function KillAltCharacter()
    local char = LocalPlayer.Character
    if not char then return end
    pcall(function()
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end)
    pcall(function() char:BreakJoints() end)
    pcall(function()
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            local exp = Instance.new("Explosion")
            exp.BlastRadius   = 0
            exp.BlastPressure = 0
            exp.Position      = root.Position
            exp.Parent        = Workspace
            game:GetService("Debris"):AddItem(exp, 1)
        end
    end)
end

local function IsMissionNotification(child)
    local nameLower = child.Name:lower()
    if nameLower:find("your opponent is") then return true end
    for _, desc in ipairs(child:GetDescendants()) do
        if desc:IsA("TextLabel") then
            if desc.Text:lower():find("your opponent is") then return true end
        end
    end
    return false
end

local function IsMissionEndNotification(child)
    local nameLower = child.Name:lower()
    if nameLower:find("mission complete") or nameLower:find("mission failed") then return true end
    for _, desc in ipairs(child:GetDescendants()) do
        if desc:IsA("TextLabel") then
            local t = desc.Text:lower()
            if t:find("mission complete") or t:find("mission failed") then return true end
        end
    end
    return false
end

