local EXTRACT_PATTERNS = {
    "[Tt]alk%s+[Tt]o:%s*(.+)",
    "[Ss]peak%s+[Tt]o:%s*(.+)",
    "[Ss]peak%s+[Ww]ith:%s*(.+)",
