    if altMissionWatchConn then
        altMissionWatchConn:Disconnect()
        altMissionWatchConn = nil
    end
end

local function StopQueueWatch()
    if queueWatchConn then
        queueWatchConn:Disconnect()
        queueWatchConn = nil
    end
end

local altRespawnConn = nil

local function StopAltRespawnWatch()
    if altRespawnConn then altRespawnConn:Disconnect() altRespawnConn = nil end
end

local function StartAltRespawnWatch()
    StopAltRespawnWatch()
    altRespawnConn = LocalPlayer.CharacterAdded:Connect(function()
        if not autoLevelEnabled or autoLevelMode ~= "Alt" or not StillValid() then
            StopAltRespawnWatch()
            return
        end

        task.wait(0.5)
        TryAutoSpawn()
        task.wait(0.3)

        if not pvpQueuedFlag then
            local board = FindClosestPvPBoard()
            if board then
                local boardCF   = board.part.CFrame
                local boardSize = board.part.Size
                local behindCF  = boardCF
                    * CFrame.new(0, boardSize.Y * 0.5 + 1, boardSize.Z * 0.5 + 2)

                SafeTeleport(behindCF)
                task.wait(0.3)

                local fired = FireBoardPrompt(board.model)
                if not fired then SimulateKeyPress(Enum.KeyCode.E) end

                local waited = 0
                while not pvpQueuedFlag and waited < 3 do
                    task.wait(0.2)
                    waited = waited + 0.2
                end

                Library:Notify({
                    Title       = "Auto Level",
                    Description = pvpQueuedFlag and "Alt re-queued!" or "Prompt fired — queue pending.",
                    Time        = 3,
                })
            else
                Library:Notify({
                    Title       = "Auto Level",
                    Description = "Alt respawned — board not found, loop will retry.",
                    Time        = 3,
                })
            end
        end
    end)
end

local function StartQueueWatch()
    StopQueueWatch()
    StopAltMissionWatch()

    local function TryConnect()
        local gui    = LocalPlayer:FindFirstChild("PlayerGui")
        local notifs = gui and gui:FindFirstChild("Notifications")
        local holder = notifs and notifs:FindFirstChild("holder")
        if not holder then return false end

        queueWatchConn = holder.ChildAdded:Connect(function(child)
            if not autoLevelEnabled or not StillValid() then
                StopQueueWatch()
                return
            end

            local nameLower = child.Name:lower()

            if nameLower:find("joined pvp mission queue") then
                pvpQueuedFlag = true
            end

            if nameLower:find("left pvp mission queue") then
                pvpQueuedFlag = false
            end

            if IsMissionNotification(child) then
                pvpQueuedFlag = false

                if autoLevelMode == "Alt" then
                    Library:Notify({
                        Title       = "Auto Level",
                        Description = "Opponent found — killing alt, will re-queue on respawn.",
                        Time        = 4,
                    })
                    StartAltRespawnWatch()
                    task.spawn(KillAltCharacter)
                else
                    Library:Notify({
                        Title       = "Auto Level",
                        Description = "Mission started! Waiting for result...",
                        Time        = 3,
                    })
                end
            end

            if IsMissionEndNotification(child) then
                pvpQueuedFlag = false
                Library:Notify({
                    Title       = "Auto Level",
                    Description = child.Name .. " — re-queuing shortly.",
                    Time        = 3,
                })
            end
        end)
        return true
    end

    if not TryConnect() then
        task.spawn(function()
            for _ = 1, 30 do
                task.wait(1)
                if not autoLevelEnabled or not StillValid() then return end
                if TryConnect() then return end
            end
        end)
    end
end

local function StopAutoLevel()
    autoLevelEnabled = false
    pvpQueuedFlag    = false
    StopQueueWatch()
    StopAltMissionWatch()
    StopAltRespawnWatch()
    if autoLevelThread then task.cancel(autoLevelThread) autoLevelThread = nil end
end

local function StartAutoLevel()
    StopAutoLevel()
    autoLevelEnabled = true
    pvpQueuedFlag    = false

    StartQueueWatch()

    autoLevelThread = task.spawn(function()
        while autoLevelEnabled and StillValid() do

            if not pvpQueuedFlag then
                local board = FindClosestPvPBoard()

                if not board then
                    Library:Notify({
                        Title       = "Auto Level",
                        Description = "PvP Mission Board not found in Map!",
                        Time        = 4,
                    })
                    task.wait(5)
                else
                    local boardCF   = board.part.CFrame
                    local boardSize = board.part.Size
                    local behindCF  = boardCF
                        * CFrame.new(0, boardSize.Y * 0.5 + 1, boardSize.Z * 0.5 + 2)

                    SafeTeleport(behindCF)
                    task.wait(0.4)

                    local fired = FireBoardPrompt(board.model)
                    if not fired then
                        SimulateKeyPress(Enum.KeyCode.E)
                    end

                    local waited = 0
                    while not pvpQueuedFlag and waited < 3 do
                        task.wait(0.2)
                        waited = waited + 0.2
                    end

                    if pvpQueuedFlag then
                        Library:Notify({
                            Title       = "Auto Level",
                            Description = "Joined PvP Queue! (" .. autoLevelMode .. ")"
                                          .. (autoLevelMode == "Alt" and " — watching for opponent." or ""),
                            Time        = 3,
                        })
                    else
                        Library:Notify({
                            Title       = "Auto Level",
                            Description = "Prompt fired — no confirm yet. Retrying.",
                            Time        = 2,
                        })
                    end
                end
            end

            task.wait(3)
        end
    end)
end

