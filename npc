local function StopAutoAttack()
    autoAttackEnabled = false
    if attackThread then task.cancel(attackThread) attackThread = nil end
end

local function StartAutoAttack()
    StopAutoAttack()
    autoAttackEnabled = true
    attackThread = task.spawn(function()
        while autoAttackEnabled and StillValid() do
            for _, key in ipairs(ATTACK_KEYS_ORDER) do
                if selectedAttackKeys[key] then
                    local action = ATTACK_ACTIONS[key]
                    if action then pcall(action) end
                end
            end
            task.wait(0)
        end
    end)
end

