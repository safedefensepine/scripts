-- ──────────────────────────────────────────────
-- Left — Current Quest
-- ──────────────────────────────────────────────

local QuestBox = Tabs.Main:AddLeftGroupbox("Current Quest")

local QuestLabel = QuestBox:AddLabel("Quest NPC: detecting...")

local function UpdateQuestLabel()
    local name = GetQuestNPCName()
    local markers = GetAllQuestMarkers()
    local markerText = #markers > 0 and (" | " .. #markers .. " marker(s)") or ""
    QuestLabel:SetText(
        name and ("Quest NPC: " .. name .. markerText)
              or ("Quest NPC: not detected" .. markerText)
    )
end

UpdateQuestLabel()

QuestBox:AddButton({
    Text = "Talk to Quest NPC",
    Tooltip = "Fire dialogue for the detected quest NPC",
    Func = function()
        local name = GetQuestNPCName()
        if not name then
            Library:Notify({ Title = "Error", Description = "No quest NPC detected.", Time = 3 })
            return
        end
        UpdateQuestLabel()
        FireDialogue(name, 1)
    end,
})

QuestBox:AddButton({
    Text = "TP to Quest",
    Tooltip = "Teleport to the next quest marker (cycles through all markers)",
    Func = function()
        TeleportToQuest()
        UpdateQuestLabel()
    end,
})

QuestBox:AddButton({
    Text = "Refresh Quest",
    Tooltip = "Re-scan quest labels and markers",
    Func = function()
        questMarkerIndex = 0
        UpdateQuestLabel()
        local markers = GetAllQuestMarkers()
        Library:Notify({
            Title = "Refreshed",
            Description = #markers .. " quest marker(s) found.",
            Time = 3,
        })
    end,
})

QuestBox:AddButton({
    Text = "DEBUG: Print Quest Labels",
    Tooltip = "Prints all PlayerGui TextLabels and quest markers to console",
    Func = function()
        local gui = LocalPlayer.PlayerGui
        local taskHolder = WalkPath(gui, { "menu", "task_holder" })
        if not taskHolder then
            print("[DEBUG] task_holder not found")
            Library:Notify({ Title = "DEBUG", Description = "task_holder not found!", Time = 4 })
            return
        end
        print("[DEBUG] Scanning task_holder TextLabels only...")
        local count = 0
        for _, obj in ipairs(taskHolder:GetDescendants()) do
            if obj:IsA("TextLabel") and obj.Text ~= "" then
                count = count + 1
                print("[DEBUG] Path: " .. obj:GetFullName())
                print("[DEBUG] Text: " .. obj.Text)
            end
        end
        local markers = GetAllQuestMarkers()
        print("[DEBUG] Quest markers: " .. #markers)
        for i, m in ipairs(markers) do
            print("[DEBUG] Marker " .. i .. ": '" .. m.title .. "' @ " .. tostring(m.pos))
        end
        local detected = GetQuestNPCName()
        print("[DEBUG] Detected NPC: " .. tostring(detected))
        Library:Notify({
            Title = "DEBUG",
            Description = count .. " labels, " .. #markers .. " markers. Check console.",
            Time = 3,
        })
    end,
})

QuestBox:AddDivider()

-- ──────────────────────────────────────────────
-- Left — Manual Select
-- ──────────────────────────────────────────────

QuestBox:AddLabel("— Manual Select —")

QuestBox:AddDropdown("NPCSelect", {
    Values = npcNames,
    Default = 1,
    Text = "Select NPC",
    Searchable = true,
    Callback = function(Value)
        SelectedNPC = Value
    end,
})

QuestBox:AddDivider()

QuestBox:AddButton({
    Text = "Talk to NPC",
    Func = function() FireDialogue(SelectedNPC, 1) end,
})

QuestBox:AddButton({
    Text = "TP to NPC",
    Func = function() TeleportToQuest() end,
})

-- ──────────────────────────────────────────────
-- Right — Options
-- ──────────────────────────────────────────────

local RightBox = Tabs.Main:AddRightGroupbox("Options")

RightBox:AddButton({
    Text = "Refresh NPC List",
    Func = function()
        local newNames = GetNPCNames()
        Options.NPCSelect:SetValues(newNames)
        if #newNames > 0 then SelectedNPC = newNames[1] end
        Library:Notify({ Title = "Refreshed", Description = #newNames .. " NPCs found.", Time = 3 })
