-- Build a combined NPC list from all sources
local function BuildFullNPCList()
    local npcList = {}
    for _, c in ipairs(npc_cache:GetChildren()) do
        table.insert(npcList, c)
    end
    local _wsNpcs = Workspace:FindFirstChild("Npcs")
    if _wsNpcs then
        for _, c in ipairs(_wsNpcs:GetChildren()) do
            if c:IsA("Model") then table.insert(npcList, c) end
        end
    end
    local _wsLive = Workspace:FindFirstChild("Live")
    if _wsLive then
        for _, c in ipairs(_wsLive:GetChildren()) do
            if c:IsA("Model") then table.insert(npcList, c) end
        end
    end
    local _wsMap = Workspace:FindFirstChild("Map")
    if _wsMap then
        for _, c in ipairs(_wsMap:GetDescendants()) do
            if c:IsA("Model") and c:FindFirstChildOfClass("Humanoid") then
                table.insert(npcList, c)
            end
        end
    end
    -- Sort longest name first so partial matches prefer more specific
    table.sort(npcList, function(a, b) return #a.Name > #b.Name end)
    return npcList
end

-- Extract ALL task texts from the task_holder UI, priority-sorted
local function GetAllTaskTexts()
    local priority, fallback = {}, {}
    local gui = LocalPlayer.PlayerGui
    local taskHolder = WalkPath(gui, { "menu", "task_holder" })
    if not taskHolder then return priority, fallback end
    for _, obj in ipairs(taskHolder:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Text ~= "" then
            local cleaned = obj.Text
                :gsub("<[^>]+>", "")
                :gsub("[「」『』【】〔〕]", "")
                :gsub("%[.-%]", "")
                :gsub("%(.-%)", "")
                :gsub("%s+", " ")
                :match("^%s*(.-)%s*$")
            if cleaned ~= "" then
                if IsQuestActionText(cleaned) then
                    table.insert(priority, cleaned)
                else
                    table.insert(fallback, cleaned)
                end
            end
        end
    end
    return priority, fallback
end

-- Returns ALL quest NPC names from the active task list.
-- Dead-simple approach: scan every visible TextLabel in task_holder,
-- only parse lines that contain a quest action keyword, skip strikethroughs.
local function GetAllQuestNPCNames()
    local found = {}
    local seen  = {}
    pcall(function()
        local npcList    = BuildFullNPCList()
        local gui        = LocalPlayer.PlayerGui
        local taskHolder = WalkPath(gui, { "menu", "task_holder" })
        if not taskHolder then return end

        for _, obj in ipairs(taskHolder:GetDescendants()) do
            if not (obj:IsA("TextLabel") and obj.Text ~= "") then continue end
            -- Skip dim (completed) labels
            if obj.TextTransparency > 0.6 then continue end
            -- Skip strikethrough rich text
            local raw = obj.Text
            if raw:find("<s>") then continue end

            local cleaned = raw
                :gsub("<[^>]+>", "")
                :gsub("[「」『』【】〔〕]", "")
                :gsub("%[.-%]", "")
                :gsub("%(.-%)", "")
                :gsub("%s+", " ")
                :match("^%s*(.-)%s*$")

            if cleaned == "" then continue end
            -- Must contain a quest action word to be parsed
            if not IsQuestActionText(cleaned) then continue end

            for _, pattern in ipairs(EXTRACT_PATTERNS) do
                local m = cleaned:match(pattern)
                if m then
                    local extracted = m:match("^%s*(.-)%s*$")
                    if extracted and extracted ~= "" then
                        local normExtracted = normalize(extracted)
                        local matched = false
                        for _, child in ipairs(npcList) do
                            local normChild = normalize(child.Name)
                            if normChild == normExtracted
                                or normExtracted:find(normChild, 1, true)
                                or normChild:find(normExtracted, 1, true) then
                                if not seen[child.Name] then
                                    seen[child.Name] = true
                                    table.insert(found, child.Name)
                                end
                                matched = true
                                break
                            end
                        end
                        if not matched and not seen[extracted] then
                            seen[extracted] = true
                            table.insert(found, extracted)
                        end
                    end
                    break
                end
            end
        end
    end)
    return found
end

local function GetQuestNPCName()
    local all = GetAllQuestNPCNames()
    return all[1]
end

