QuestBox:AddButton({
    Text    = "TP to NPC",
    Tooltip = "Teleport directly to the selected NPC",
    Func    = function()
        if not SelectedNPC or SelectedNPC == "" then
            Library:Notify({ Title = "Error", Description = "No NPC selected.", Time = 3 })
            return
        end
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then
            Library:Notify({ Title = "Error", Description = "Character not ready.", Time = 3 })
            return
        end
        local targetModel = nil
        pcall(function() targetModel = npc_cache[SelectedNPC] end)
        if not targetModel then
            pcall(function()
                local wsNpcs = Workspace:FindFirstChild("Npcs")
                if wsNpcs then targetModel = wsNpcs:FindFirstChild(SelectedNPC) end
            end)
        end
        if not targetModel then
            Library:Notify({ Title = "Error", Description = "'" .. SelectedNPC .. "' not found in world.", Time = 3 })
            return
        end
        local targetPart = targetModel:FindFirstChild("HumanoidRootPart")
                        or targetModel:FindFirstChildOfClass("BasePart")
                        or targetModel:FindFirstChildWhichIsA("BasePart", true)
        if not targetPart then
            Library:Notify({ Title = "Error", Description = "Could not find a part on '" .. SelectedNPC .. "'.", Time = 3 })
            return
        end
        SafeTeleport(targetPart.CFrame + Vector3.new(0, 4, 0))
        Library:Notify({ Title = "TP to NPC", Description = "Teleported to: " .. SelectedNPC, Time = 2 })
    end,
})

