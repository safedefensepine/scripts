local function IsDialogueOpen()
    local gui = LocalPlayer.PlayerGui
    local candidates = {
        { "menu", "dialogue" },
        { "menu", "dialogue_holder" },
        { "menu", "npc_dialogue" },
        { "menu", "dialog" },
        { "DialogueGui" },
        { "dialogue_gui" },
        { "NPCDialogue" },
    }
    for _, path in ipairs(candidates) do
        local obj = WalkPath(gui, path)
        if obj then
            if obj:IsA("GuiObject") then
                if obj.Visible then return true end
            else
                for _, child in ipairs(obj:GetChildren()) do
                    if child:IsA("GuiObject") and child.Visible then return true end
                end
            end
        end
    end
    for _, screenGui in ipairs(gui:GetChildren()) do
        if screenGui:IsA("ScreenGui") then
            for _, desc in ipairs(screenGui:GetDescendants()) do
                if desc:IsA("GuiObject") and desc.Visible then
                    local nameLower = desc.Name:lower()
                    if nameLower:find("dialogue") or nameLower:find("dialog") or nameLower:find("npc") then
                        return true
                    end
                end
            end
        end
    end
    return false
end

