    Default = "100", Numeric = true, Finished = true, Text = "Destructive Power Cap",
    Callback = function(v) local n = tonumber(v) if n and n > 0 then statCaps.DestructivePowerStat = math.floor(n) end end,
})

AutoStatBox:AddInput("CapDestructiveEnergy", {
    Default = "100", Numeric = true, Finished = true, Text = "Destructive Energy Cap",
    Callback = function(v) local n = tonumber(v) if n and n > 0 then statCaps.DestructiveEnergyStat = math.floor(n) end end,
})

AutoStatBox:AddDivider()

AutoStatBox:AddDropdown("StatSelect", {
    Values   = STAT_NAMES,
    Default  = {},
    Text     = "Stats to Level",
    Multi    = true,
    Callback = function(Value)
        selectedStats = {}
        for stat, enabled in pairs(Value) do
            if enabled then selectedStats[stat] = true end
        end
        if autoStatEnabled then StartAutoStat() end
    end,
})

AutoStatBox:AddToggle("AutoStatToggle", {
    Text     = "Auto Stat",
    Default  = false,
    Callback = function(Value)
        if Value then
            if not next(selectedStats) then
                Library:Notify({ Title = "Auto Stat", Description = "Select at least one stat first!", Time = 3 })
                pcall(function() Options.AutoStatToggle:SetValue(false) end)
                return
            end
            StartAutoStat()
            Library:Notify({ Title = "Auto Stat", Description = "Enabled.", Time = 2 })
        else
            StopAutoStat()
            Library:Notify({ Title = "Auto Stat", Description = "Disabled.", Time = 2 })
        end
    end,
})

