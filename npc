local StatEvent = ReplicatedStorage.requests.character.increase_stat

local STAT_NAMES = {
    "StrengthStat",
    "DefenseStat",
    "PowerStat",
    "WeaponStat",
    "DestructivePowerStat",
    "DestructiveEnergyStat",
}

local STAT_FOLDER_MAP = {
    StrengthStat          = "strength",
    DefenseStat           = "defense",
    PowerStat             = "power",
    WeaponStat            = "weapon",
    DestructivePowerStat  = "destructive_power",
    DestructiveEnergyStat = "destructive_energy",
}

local autoStatEnabled = false
local autoStatThread  = nil
local selectedStats   = {}
local autoStatDelay   = 0.1

local statCaps = {
    StrengthStat          = 100,
    DefenseStat           = 100,
    PowerStat             = 100,
    WeaponStat            = 100,
    DestructivePowerStat  = 100,
    DestructiveEnergyStat = 100,
}

local function GetCurrentStatValue(statName)
    local val = 0
    pcall(function()
        local folder = STAT_FOLDER_MAP[statName]
        if not folder then return end
        local normFolder = folder:lower():gsub("[%s_%-]", "")

        local gui  = LocalPlayer:FindFirstChild("PlayerGui")
        local menu = gui and gui:FindFirstChild("menu")
        if not menu then return end

        -- Broad search: find any object whose normalised name matches the
        -- stat folder, then look for a child label with a number in it.
        for _, obj in ipairs(menu:GetDescendants()) do
            local normName = obj.Name:lower():gsub("[%s_%-]", "")
            if normName == normFolder then
                local candidates = { obj:FindFirstChild("stat_amount") }
                for _, child in ipairs(obj:GetChildren()) do
                    if child:IsA("TextLabel") then
                        table.insert(candidates, child)
                    end
                end
                for _, label in ipairs(candidates) do
                    if label and label:IsA("TextLabel") then
                        local clean = label.Text:gsub("<[^>]+>", "")
                        local num   = clean:match("(%d+)")
                        if num then
                            val = tonumber(num) or 0
                            return
                        end
                    end
                end
            end
        end
    end)
    return val
end

local function StopAutoStat()
    autoStatEnabled = false
    if autoStatThread then task.cancel(autoStatThread) autoStatThread = nil end
end

local function StartAutoStat()
    StopAutoStat()
    autoStatEnabled = true
    autoStatThread = task.spawn(function()
        while autoStatEnabled and StillValid() do
            local anyFired  = false
            local allCapped = true

            for _, stat in ipairs(STAT_NAMES) do
                if selectedStats[stat] then
                    local current = GetCurrentStatValue(stat)
                    local cap     = statCaps[stat] or 100
                    if current < cap then
                        allCapped = false
                        pcall(function() StatEvent:FireServer(stat, 1) end)
                        anyFired = true
                    end
                end
            end

            if next(selectedStats) and allCapped then
                autoStatEnabled = false
                pcall(function() Options.AutoStatToggle:SetValue(false) end)
                Library:Notify({
                    Title       = "Auto Stat",
                    Description = "All selected stats reached their caps!",
                    Time        = 4,
                })
                return
            end

            task.wait(anyFired and autoStatDelay or 0.5)
        end
    end)
end

