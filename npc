        print("[DEBUG] Scanning all visible ScreenGui frames...")
        for _, sg in ipairs(gui:GetChildren()) do
            if sg:IsA("ScreenGui") then
                for _, desc in ipairs(sg:GetDescendants()) do
                    if desc:IsA("GuiObject") and desc.Visible then
