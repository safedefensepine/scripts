        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then savedRaidPosition = root.CFrame end
    end)

    raidNoclipHB = RunService.Heartbeat:Connect(function()
        if not autoRaidEnabled or not StillValid() then
            raidNoclipHB:Disconnect() raidNoclipHB = nil return
        end
        local char = LocalPlayer.Character
        if not char then return end
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)

    raidHeartbeat = RunService.Heartbeat:Connect(function(dt)
        if not autoRaidEnabled or not StillValid() then
            raidHeartbeat:Disconnect() raidHeartbeat = nil return
        end

        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local npcRoot = FindRaidTarget()

        if npcRoot then
            root.CFrame = npcRoot.CFrame * RAID_OFFSET
            pcall(function()
                root.AssemblyLinearVelocity  = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end)
            raidClearTimer = 0
            raidHasSeenMob = true
        elseif raidHasSeenMob then
            raidClearTimer = raidClearTimer + dt
            if raidClearTimer >= 10 then
                raidHeartbeat:Disconnect() raidHeartbeat = nil
                Library:Notify({ Title = "Auto Raid", Description = "All mobs cleared! Returning home.", Time = 4 })
                RestoreAfterRaid()
            end
        end
    end)
end

