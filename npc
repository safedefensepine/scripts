local function TeleportToQuest()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then
        Library:Notify({ Title = "Error", Description = "Character not ready.", Time = 3 })
        return
    end
    local markers = GetAllQuestMarkers()
    if #markers == 0 then
        Library:Notify({ Title = "Error", Description = "No quest markers found.", Time = 3 })
        return
    end
    questMarkerIndex = (questMarkerIndex % #markers) + 1
    local marker = markers[questMarkerIndex]
    SafeTeleport(marker.part.CFrame + Vector3.new(0, 4, 0))
    local label = (#markers > 1) and (" (" .. questMarkerIndex .. "/" .. #markers .. ")") or ""
    Library:Notify({ Title = "TP to Quest", Description = marker.title .. label, Time = 2 })
end

