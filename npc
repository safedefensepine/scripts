local autoRaidEnabled   = false
local raidHeartbeat     = nil
local raidNoclipHB      = nil
local raidRetryThread   = nil
local autoRetryEnabled  = false
local savedRaidPosition = nil
local raidClearTimer    = 0
local raidHasSeenMob    = false

local RAID_OFFSET = CFrame.new(0, -9, 0) * CFrame.Angles(math.pi / 2, 0, 0)

local function FindRaidTarget()
    local live = Workspace:FindFirstChild("Live")
    if not live then return nil end
    for _, obj in ipairs(live:GetChildren()) do
        if obj:IsA("Model")
            and obj.Name:find(".", 1, true)
            and not obj.Name:lower():find("hostage", 1, true)
        then
            local hum  = obj:FindFirstChildOfClass("Humanoid")
            local root = obj:FindFirstChild("HumanoidRootPart")
                      or obj:FindFirstChildWhichIsA("BasePart", true)
            if hum and root and hum.Health > 0 then
                return root
            end
        end
    end
    return nil
end

local function RestoreAfterRaid()
    autoRaidEnabled = false
    raidClearTimer  = 0
    raidHasSeenMob  = false
    if raidHeartbeat then raidHeartbeat:Disconnect() raidHeartbeat = nil end
    if raidNoclipHB  then raidNoclipHB:Disconnect()  raidNoclipHB  = nil end
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = true end
        end
    end)
    if savedRaidPosition then
        SafeTeleport(savedRaidPosition)
        savedRaidPosition = nil
    end
end

local function StopAutoRaid()
    RestoreAfterRaid()
    pcall(function() Options.StartAutoRaid:SetValue(false) end)
end

local function StartAutoRaid()
    autoRaidEnabled = true
    raidClearTimer  = 0
    raidHasSeenMob  = false

    pcall(function()
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then savedRaidPosition = root.CFrame end
    end)

    raidNoclipHB = RunService.Heartbeat:Connect(function()
        if not autoRaidEnabled or not StillValid() then
            raidNoclipHB:Disconnect() raidNoclipHB = nil return
        end
        local char = LocalPlayer.Character
        if not char then return end
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)

    raidHeartbeat = RunService.Heartbeat:Connect(function(dt)
        if not autoRaidEnabled or not StillValid() then
            raidHeartbeat:Disconnect() raidHeartbeat = nil return
        end

        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local npcRoot = FindRaidTarget()

        if npcRoot then
            root.CFrame = npcRoot.CFrame * RAID_OFFSET
            pcall(function()
                root.AssemblyLinearVelocity  = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end)
            raidClearTimer = 0
            raidHasSeenMob = true
        elseif raidHasSeenMob then
            raidClearTimer = raidClearTimer + dt
            if raidClearTimer >= 10 then
                raidHeartbeat:Disconnect() raidHeartbeat = nil
                Library:Notify({ Title = "Auto Raid", Description = "All mobs cleared! Returning home.", Time = 4 })
                RestoreAfterRaid()
            end
        end
    end)
end

