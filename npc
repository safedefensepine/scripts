-- Left — Current Quest
-- ──────────────────────────────────────────────

local QuestBox = Tabs.Main:AddLeftGroupbox("Current Quest")

local QuestLabel = QuestBox:AddLabel("Quest NPC: detecting...")

local function UpdateQuestLabel()
    local name = GetQuestNPCName()
    local markers = GetAllQuestMarkers()
    local markerText = #markers > 0 and (" | " .. #markers .. " marker(s)") or ""
    QuestLabel:SetText(name and ("Quest NPC: " .. name .. markerText) or ("Quest NPC: not detected" .. markerText))
end

UpdateQuestLabel()

QuestBox:AddButton({
    Text = "Talk to Quest NPC",
    Tooltip = "Fire dialogue for the active quest NPC",
    Func = function()
        local name = GetQuestNPCName()
        if not name then
            Library:Notify({ Title = "Error", Description = "No quest NPC detected.", Time = 3 })
            return
        end
        UpdateQuestLabel()
        FireDialogue(name, 1)
    end,
})

QuestBox:AddButton({
    Text = "TP to Quest",
    Tooltip = "Teleport to next quest marker. Always cycles.",
    Func = function()
        TeleportToNextQuestMarker()
        UpdateQuestLabel()
    end,
})

QuestBox:AddButton({
    Text = "Refresh Quest",
    Tooltip = "Re-scan quest label and markers",
    Func = function()
        questMarkerIndex = 0
        UpdateQuestLabel()
        local markers = GetAllQuestMarkers()
        Library:Notify({
            Title = "Refreshed",
            Description = #markers .. " quest marker(s) found.",
            Time = 3,
        })
    end,
})

QuestBox:AddButton({
    Text = "DEBUG: Print Quest Labels",
    Tooltip = "Prints TextLabels and quest markers to console",
    Func = function()
        local gui = LocalPlayer.PlayerGui
        local holder = WalkPath(gui, { "menu", "task_holder" })
        if not holder then
            print("[DEBUG] task_holder not found")
            Library:Notify({ Title = "DEBUG", Description = "task_holder not found!", Time = 4 })
            return
        end
        print("[DEBUG] Scanning task_holder...")
        local count = 0
        for _, obj in ipairs(holder:GetDescendants()) do
            if obj:IsA("TextLabel") and obj.Text ~= "" then
                count = count + 1
                print("[DEBUG] Path: " .. obj:GetFullName())
                print("[DEBUG] Text: " .. obj.Text)
            end
        end
        local markers = GetAllQuestMarkers()
        print("[DEBUG] Quest markers: " .. #markers)
        for i, m in ipairs(markers) do
            print("[DEBUG] Marker " .. i .. ": '" .. m.title .. "' @ " .. tostring(m.pos))
        end
        Library:Notify({ Title = "DEBUG", Description = count .. " labels, " .. #markers .. " markers. Check console.", Time = 3 })
    end,
})

