-- Find NPC in World  (FIXED – searches more locations)
-- ──────────────────────────────────────────────

-- Search ONLY real world locations for a teleport target.
-- npc_cache is in ReplicatedStorage — it has NO world CFrame, so it is
-- intentionally excluded here. Use FindNPCModelForDialogue for cache lookups.
local function FindQuestNPCInWorld(npcName)
    if not npcName or npcName == "" then return nil end
    local normTarget = normalize(npcName)

    local function matchName(name)
        local n = normalize(name)
        return n == normTarget
            or n:find(normTarget, 1, true)
            or normTarget:find(n, 1, true)
    end

    -- Search direct children of a folder (fast path for Live / Npcs)
    local function searchChildren(folder, isHostile)
        if not folder then return nil end
        for _, obj in ipairs(folder:GetChildren()) do
            if obj:IsA("Model") and matchName(obj.Name) then
                local hum  = obj:FindFirstChildOfClass("Humanoid")
                local root = obj:FindFirstChild("HumanoidRootPart")
                          or obj:FindFirstChildWhichIsA("BasePart", true)
                if root and (not hum or hum.Health > 0) then
                    return { root = root, hostile = isHostile, model = obj }
                end
            end
        end
        return nil
    end

    -- Deep search across ALL of Workspace (catches NPCs in any sub-folder)
    local function searchWorkspaceDeep()
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and matchName(obj.Name) then
                local hum  = obj:FindFirstChildOfClass("Humanoid")
                local root = obj:FindFirstChild("HumanoidRootPart")
                          or obj:FindFirstChildWhichIsA("BasePart", true)
                if root and (not hum or hum.Health > 0) then
                    -- Determine hostility: Live folder = hostile
                    local isHostile = false
                    local p = obj.Parent
                    while p and p ~= Workspace do
                        if p.Name == "Live" then isHostile = true break end
                        p = p.Parent
                    end
                    return { root = root, hostile = isHostile, model = obj }
                end
            end
        end
        return nil
    end

    -- Priority: Live children (fast) > Npcs children (fast) > full Workspace deep scan
    return searchChildren(Workspace:FindFirstChild("Live"), true)
        or searchChildren(Workspace:FindFirstChild("Npcs"), false)
        or searchWorkspaceDeep()
end

-- Separate lookup purely for firing the dialogue RemoteEvent.
-- Checks npc_cache first (no world position needed), then world.
local function FindNPCModelForDialogue(npcName)
    if not npcName or npcName == "" then return nil end
    local normTarget = normalize(npcName)
    local function matchName(name)
        local n = normalize(name)
        return n == normTarget
            or n:find(normTarget, 1, true)
            or normTarget:find(n, 1, true)
    end
    -- 1. npc_cache (ReplicatedStorage) — preferred for dialogue
    for _, c in ipairs(npc_cache:GetChildren()) do
        if matchName(c.Name) then return c end
    end
    -- 2. Workspace.Npcs
    local wsNpcs = Workspace:FindFirstChild("Npcs")
    if wsNpcs then
        for _, c in ipairs(wsNpcs:GetChildren()) do
            if c:IsA("Model") and matchName(c.Name) then return c end
        end
    end
    -- 3. Workspace.Live
    local wsLive = Workspace:FindFirstChild("Live")
    if wsLive then
        for _, c in ipairs(wsLive:GetChildren()) do
            if c:IsA("Model") and matchName(c.Name) then return c end
        end
    end
    -- 4. Full deep scan
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and matchName(obj.Name) then return obj end
    end
    return nil
end

